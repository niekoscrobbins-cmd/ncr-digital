---
const stats = [
  { value: 'DA 44',  label: 'Peak Authority Hit' },
  { value: '7 mo',   label: 'DA 20→44 Sprint' },
  { value: '3.2x',   label: 'Avg Traffic Growth' },
];
---

<section
  class="relative min-h-screen flex flex-col justify-center pt-16 overflow-hidden"
  aria-label="Hero"
>
  <!-- Background: grid + glow -->
  <div
    class="absolute inset-0 bg-grid-pattern bg-[size:50px_50px]"
    aria-hidden="true"
  ></div>
  <div
    class="absolute inset-0 bg-hero-glow"
    aria-hidden="true"
  ></div>
  <!-- Side accent lines -->
  <div
    class="absolute left-0 top-1/4 h-px w-1/3 bg-gradient-to-r from-transparent via-ncr-cyan/20 to-transparent"
    aria-hidden="true"
  ></div>
  <div
    class="absolute right-0 bottom-1/4 h-px w-1/3 bg-gradient-to-l from-transparent via-ncr-cyan/20 to-transparent"
    aria-hidden="true"
  ></div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 md:py-32">
    <!-- Eyebrow -->
    <p class="font-mono text-ncr-cyan text-xs tracking-[0.3em] uppercase mb-7 flex items-center gap-3">
      <span class="inline-block h-px w-8 bg-ncr-cyan" aria-hidden="true"></span>
      Technical SEO Agency
    </p>

    <!-- H1 -->
    <h1 class="text-5xl sm:text-6xl lg:text-7xl xl:text-8xl font-extrabold tracking-tight leading-[1.05] mb-7 max-w-5xl">
      Technical SEO for<br />
      <span class="text-transparent bg-clip-text bg-gradient-to-r from-ncr-cyan via-blue-400 to-ncr-cyan">
        High-Growth
      </span>
      &nbsp;Ventures.
    </h1>

    <!-- Subheadline -->
    <p class="text-ncr-muted text-lg sm:text-xl max-w-2xl mb-12 leading-relaxed">
      We architect search dominance for ambitious startups and mid-market firms.
      Data-driven audits. Precision content strategy. Measurable rankings growth.
    </p>

    <!-- CTAs -->
    <div class="flex flex-wrap gap-4 mb-24" role="group" aria-label="Primary actions">
      <a
        href="#contact"
        class="inline-flex items-center gap-2 px-7 py-3.5 bg-ncr-cyan text-ncr-bg font-semibold text-sm tracking-wide hover:bg-[#00ccdd] active:scale-[0.98] transition-all duration-200"
      >
        Start Your Audit
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="square">
          <path d="M3 8h10M9 4l4 4-4 4"/>
        </svg>
      </a>
      <a
        href="#case-studies"
        class="inline-flex items-center gap-2 px-7 py-3.5 border border-ncr-border text-ncr-text text-sm tracking-wide hover:border-ncr-cyan/60 hover:text-ncr-cyan transition-all duration-200"
      >
        View Case Study
      </a>
    </div>

    <!-- Stats -->
    <div
      class="grid grid-cols-3 sm:grid-cols-3 gap-6 sm:gap-10 border-t border-ncr-border pt-10 max-w-lg"
      role="list"
      aria-label="Key metrics"
    >
      {stats.map(({ value, label }) => (
        <div role="listitem">
          <p class="font-mono text-2xl sm:text-3xl font-bold text-ncr-cyan tracking-tight">{value}</p>
          <p class="text-ncr-muted text-xs sm:text-sm mt-1 leading-snug">{label}</p>
        </div>
      ))}
    </div>
  </div>

  <!-- Bottom fade -->
  <div
    class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-ncr-bg to-transparent"
    aria-hidden="true"
  ></div>
</section>
