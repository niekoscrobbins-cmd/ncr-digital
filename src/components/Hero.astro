---
const stats = [
  { value: 'DA 44',  label: 'Peak Authority Hit',   icon: '▲' },
  { value: '7 mo',   label: 'DA 20→44 Sprint',      icon: '◆' },
  { value: '3.2x',   label: 'Avg Traffic Growth',   icon: '▲' },
];
---

<section
  class="relative min-h-screen flex flex-col justify-center pt-16 overflow-hidden bg-ncr-bg"
  aria-label="Hero"
>

  <!-- ── Layered background ────────────────────────────────── -->
  <!-- Dot grid -->
  <div
    class="absolute inset-0"
    style="background-image: radial-gradient(rgba(0,229,255,0.07) 1px, transparent 1px); background-size: 28px 28px;"
    aria-hidden="true"
  ></div>

  <!-- Top-center radial bloom -->
  <div
    class="absolute -top-40 left-1/2 -translate-x-1/2 w-[800px] h-[500px] rounded-full"
    style="background: radial-gradient(ellipse at center, rgba(0,229,255,0.10) 0%, transparent 70%);"
    aria-hidden="true"
  ></div>

  <!-- Bottom-left secondary bloom -->
  <div
    class="absolute -bottom-32 -left-32 w-[500px] h-[500px] rounded-full"
    style="background: radial-gradient(ellipse at center, rgba(79,142,247,0.07) 0%, transparent 70%);"
    aria-hidden="true"
  ></div>

  <!-- Horizontal accent lines -->
  <div class="absolute top-1/3 left-0 h-px w-2/5 bg-gradient-to-r from-ncr-cyan/25 via-ncr-cyan/10 to-transparent" aria-hidden="true"></div>
  <div class="absolute bottom-1/3 right-0 h-px w-2/5 bg-gradient-to-l from-ncr-cyan/25 via-ncr-cyan/10 to-transparent" aria-hidden="true"></div>

  <!-- ── Content ───────────────────────────────────────────── -->
  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-28 md:py-36 w-full">

    <!-- Eyebrow pill -->
    <div class="inline-flex items-center gap-2.5 border border-ncr-cyan/25 bg-ncr-cyan/5 px-4 py-1.5 mb-10 rounded-sm">
      <span class="w-1.5 h-1.5 rounded-full bg-ncr-cyan animate-pulse" aria-hidden="true"></span>
      <span class="font-mono text-ncr-cyan text-xs tracking-[0.25em] uppercase">Technical SEO Agency — NCR Digital</span>
    </div>

    <!-- H1 — two-line stacked layout -->
    <h1 class="font-extrabold tracking-tight leading-[1.04] mb-8 max-w-5xl">
      <span class="block text-5xl sm:text-6xl lg:text-7xl xl:text-[5.25rem] text-ncr-text">
        We Don't Chase Rankings.
      </span>
      <span class="block text-5xl sm:text-6xl lg:text-7xl xl:text-[5.25rem] mt-2">
        <span class="text-transparent bg-clip-text"
          style="background-image: linear-gradient(90deg, #00e5ff 0%, #4f8ef7 50%, #00e5ff 100%); background-size: 200% auto; animation: shimmer 4s linear infinite;">
          We Engineer Them.
        </span>
      </span>
    </h1>

    <!-- Sub-headline -->
    <p class="text-ncr-muted text-lg sm:text-xl max-w-2xl mb-6 leading-relaxed">
      Bridging the gap between raw data and ROI — NCR Digital architects search dominance
      for startups and mid-market firms through technical precision and measurable strategy.
    </p>

    <!-- Trust line -->
    <p class="font-mono text-xs text-ncr-muted/60 tracking-widest uppercase mb-12">
      Technical Audits &nbsp;·&nbsp; Content Silos &nbsp;·&nbsp; Backlink Architecture &nbsp;·&nbsp; Core Web Vitals
    </p>

    <!-- CTAs -->
    <div class="flex flex-wrap gap-4 mb-24" role="group" aria-label="Primary actions">
      <a
        href="#contact"
        class="group inline-flex items-center gap-2.5 px-8 py-4 bg-ncr-cyan text-ncr-bg font-bold text-sm tracking-wider uppercase hover:bg-[#00ccdd] active:scale-[0.98] transition-all duration-200 shadow-[0_0_24px_rgba(0,229,255,0.25)] hover:shadow-[0_0_36px_rgba(0,229,255,0.40)]"
      >
        Get a Custom Quote
        <svg width="15" height="15" viewBox="0 0 15 15" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" class="group-hover:translate-x-0.5 transition-transform" aria-hidden="true">
          <path d="M2 7.5h11M8 3l5 4.5L8 12"/>
        </svg>
      </a>
      <a
        href="#case-studies"
        class="inline-flex items-center gap-2.5 px-8 py-4 border border-ncr-border/80 text-ncr-text text-sm font-semibold tracking-wider uppercase hover:border-ncr-cyan/50 hover:text-ncr-cyan hover:bg-ncr-cyan/5 transition-all duration-200"
      >
        See Results
      </a>
    </div>

    <!-- Stats row -->
    <div
      class="flex flex-wrap gap-x-10 gap-y-6 border-t border-ncr-border/60 pt-10"
      role="list"
      aria-label="Key metrics"
    >
      {stats.map(({ value, label, icon }, i) => (
        <div class="flex items-start gap-4" role="listitem">
          {i > 0 && (
            <div class="hidden sm:block self-stretch w-px bg-ncr-border/60 mt-1" aria-hidden="true"></div>
          )}
          <div class={i > 0 ? 'sm:pl-10' : ''}>
            <p class="font-mono text-3xl sm:text-4xl font-bold text-ncr-cyan tracking-tight leading-none">
              {value}
            </p>
            <p class="text-ncr-muted text-xs sm:text-sm mt-1.5 leading-snug max-w-[100px]">{label}</p>
          </div>
        </div>
      ))}
    </div>

  </div>

  <!-- Bottom fade into next section -->
  <div
    class="absolute bottom-0 left-0 right-0 h-40 bg-gradient-to-t from-ncr-bg to-transparent"
    aria-hidden="true"
  ></div>

</section>

<style>
  @keyframes shimmer {
    0%   { background-position: 0%   center; }
    100% { background-position: 200% center; }
  }
</style>
