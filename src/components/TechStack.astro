---
const tools = [
  {
    name: 'Python',
    category: 'Automation',
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>`,
  },
  {
    name: 'Google Search Console',
    category: 'Analytics',
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>`,
  },
  {
    name: 'GA4',
    category: 'Analytics',
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>`,
  },
  {
    name: 'Financial Modeling',
    category: 'Strategy',
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>`,
  },
  {
    name: 'Screaming Frog',
    category: 'Technical',
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>`,
  },
  {
    name: 'Ahrefs',
    category: 'Research',
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m3 11 19-9-9 19-2-8-8-2z"/></svg>`,
  },
  {
    name: 'Semrush',
    category: 'Research',
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg>`,
  },
  {
    name: 'JSON-LD / Schema',
    category: 'Structured Data',
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="4 7 4 4 20 4 20 7"/><line x1="9" y1="20" x2="15" y2="20"/><line x1="12" y1="4" x2="12" y2="20"/></svg>`,
  },
];
---

<section class="py-28 bg-ncr-surface border-t border-ncr-border/40" aria-labelledby="stack-heading">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <header class="mb-14">
      <p class="font-mono text-ncr-cyan text-xs tracking-[0.3em] uppercase mb-4 flex items-center gap-3">
        <span class="inline-block h-px w-8 bg-ncr-cyan" aria-hidden="true"></span>
        Instruments
      </p>
      <h2 id="stack-heading" class="text-4xl sm:text-5xl font-extrabold tracking-tight">
        Built on Precision
      </h2>
      <p class="text-ncr-muted mt-4 max-w-xl text-base leading-relaxed">
        Every engagement is powered by the same toolkit used at Porsche-backed startups —
        analytical rigor meets SEO craft.
      </p>
    </header>

    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4" role="list" aria-label="Technology stack">
      {tools.map(({ name, category, icon }) => (
        <div
          class="bg-ncr-card border border-ncr-border p-5 group hover:border-ncr-cyan/50 hover:bg-ncr-card/80 transition-all duration-200 flex flex-col gap-3"
          role="listitem"
        >
          <div class="text-ncr-cyan group-hover:text-ncr-cyan/80 transition-colors">
            <Fragment set:html={icon} />
          </div>
          <div>
            <p class="text-ncr-text text-sm font-semibold leading-tight">{name}</p>
            <p class="text-ncr-muted text-xs mt-1 font-mono tracking-wide">{category}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
