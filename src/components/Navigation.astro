---
const links = [
  { label: 'Services',     href: '#services' },
  { label: 'Case Studies', href: '#case-studies' },
  { label: 'About',        href: '#about' },
  { label: 'Contact',      href: '#contact' },
];
---

<header>
  <nav
    class="fixed top-0 left-0 right-0 z-50 border-b border-ncr-border/60 bg-ncr-bg/85 backdrop-blur-md"
    aria-label="Primary navigation"
  >
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between h-16">

        <!-- Logo -->
        <a href="/" class="font-mono font-bold text-xl tracking-widest group" aria-label="NCR Digital home">
          <span class="text-ncr-text group-hover:text-ncr-cyan transition-colors duration-200">NCR</span><!--
          --><span class="text-ncr-cyan">D</span><!--
          --><span class="text-ncr-text group-hover:text-ncr-cyan transition-colors duration-200">IGITAL</span>
        </a>

        <!-- Desktop links -->
        <div class="hidden md:flex items-center gap-8">
          {links.map(({ label, href }) => (
            <a
              href={href}
              class="text-ncr-muted hover:text-ncr-text text-sm font-medium tracking-wide transition-colors duration-200 relative group"
            >
              {label}
              <span class="absolute -bottom-0.5 left-0 h-px w-0 bg-ncr-cyan transition-all duration-300 group-hover:w-full" />
            </a>
          ))}
          <a
            href="#contact"
            class="px-5 py-2 border border-ncr-cyan text-ncr-cyan text-sm font-mono font-medium tracking-widest hover:bg-ncr-cyan hover:text-ncr-bg transition-all duration-200"
          >
            GET AUDIT →
          </a>
        </div>

        <!-- Mobile hamburger -->
        <button
          id="mobile-menu-btn"
          class="md:hidden p-2 text-ncr-muted hover:text-ncr-text transition-colors"
          aria-label="Open navigation menu"
          aria-expanded="false"
          aria-controls="mobile-menu"
        >
          <svg width="22" height="22" viewBox="0 0 22 22" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="square">
            <line x1="2" y1="5"  x2="20" y2="5"  />
            <line x1="2" y1="11" x2="20" y2="11" />
            <line x1="2" y1="17" x2="20" y2="17" />
          </svg>
        </button>
      </div>

      <!-- Mobile menu (hidden by default) -->
      <div
        id="mobile-menu"
        class="hidden md:hidden pb-5 space-y-1 border-t border-ncr-border/50 pt-4"
        role="menu"
      >
        {links.map(({ label, href }) => (
          <a
            href={href}
            class="block text-ncr-muted hover:text-ncr-text text-sm py-2.5 px-1 transition-colors"
            role="menuitem"
          >
            {label}
          </a>
        ))}
        <div class="pt-3">
          <a
            href="#contact"
            class="inline-flex items-center px-5 py-2.5 border border-ncr-cyan text-ncr-cyan text-sm font-mono hover:bg-ncr-cyan hover:text-ncr-bg transition-all duration-200"
          >
            GET AUDIT →
          </a>
        </div>
      </div>
    </div>
  </nav>
</header>

<script>
  const btn  = document.getElementById('mobile-menu-btn')!;
  const menu = document.getElementById('mobile-menu')!;

  btn.addEventListener('click', () => {
    const isOpen = !menu.classList.contains('hidden');
    menu.classList.toggle('hidden');
    btn.setAttribute('aria-expanded', String(!isOpen));
  });

  // Close menu when a link is clicked
  menu.querySelectorAll('a').forEach(link =>
    link.addEventListener('click', () => {
      menu.classList.add('hidden');
      btn.setAttribute('aria-expanded', 'false');
    })
  );
</script>
