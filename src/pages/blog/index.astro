---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Navigation from '../../components/Navigation.astro';
import Footer from '../../components/Footer.astro';

// Fetch all blog posts and sort newest first
const allPosts = await getCollection('blog');
const posts = allPosts.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

// Format date helper
function formatDate(date: Date): string {
  return date.toLocaleDateString('en-US', {
    year:  'numeric',
    month: 'long',
    day:   'numeric',
  });
}
---

<Layout
  title="Blog | NCR Digital — Technical SEO Insights"
  description="Data-driven SEO strategy, technical deep-dives, and growth frameworks from the NCR Digital team."
>
  <Navigation />

  <main id="main-content" class="pt-16">

    <!-- Page header -->
    <section class="relative py-24 overflow-hidden bg-ncr-bg">
      <!-- Dot grid bg -->
      <div
        class="absolute inset-0"
        style="background-image: radial-gradient(rgba(0,229,255,0.06) 1px, transparent 1px); background-size: 28px 28px;"
        aria-hidden="true"
      ></div>
      <!-- Top glow -->
      <div
        class="absolute -top-32 left-1/2 -translate-x-1/2 w-[600px] h-[300px] rounded-full"
        style="background: radial-gradient(ellipse at center, rgba(0,229,255,0.08) 0%, transparent 70%);"
        aria-hidden="true"
      ></div>

      <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="inline-flex items-center gap-2.5 border border-ncr-cyan/25 bg-ncr-cyan/5 px-4 py-1.5 mb-8 rounded-sm">
          <span class="w-1.5 h-1.5 rounded-full bg-ncr-cyan animate-pulse" aria-hidden="true"></span>
          <span class="font-mono text-ncr-cyan text-xs tracking-[0.25em] uppercase">NCR Digital — Insights</span>
        </div>
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold tracking-tight mb-5">
          Technical SEO,<br />
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-ncr-cyan to-blue-400">Decoded.</span>
        </h1>
        <p class="text-ncr-muted text-lg max-w-xl leading-relaxed">
          Strategy frameworks, audit walkthroughs, and data-backed growth insights — straight from the work.
        </p>
      </div>
    </section>

    <!-- Posts grid -->
    <section class="py-20 bg-ncr-surface border-t border-ncr-border/40" aria-labelledby="posts-heading">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

        <h2 id="posts-heading" class="sr-only">All posts</h2>

        {posts.length === 0 ? (
          <div class="text-center py-24">
            <p class="font-mono text-ncr-muted text-sm">No posts yet. Check back soon.</p>
          </div>
        ) : (
          <ul class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3" role="list">
            {posts.map(post => (
              <li role="listitem">
                <a
                  href={`/blog/${post.slug}/`}
                  class="group flex flex-col h-full bg-ncr-card border border-ncr-border hover:border-ncr-cyan/50 transition-colors duration-300 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ncr-cyan"
                  aria-label={`Read: ${post.data.title}`}
                >
                  <!-- Image placeholder / actual image -->
                  <div class="aspect-[16/7] bg-ncr-bg border-b border-ncr-border/60 relative overflow-hidden flex items-center justify-center">
                    {post.data.image ? (
                      <img
                        src={post.data.image}
                        alt={post.data.imageAlt ?? post.data.title}
                        width="640"
                        height="280"
                        class="w-full h-full object-cover opacity-70 group-hover:opacity-90 transition-opacity duration-300"
                        loading="lazy"
                        decoding="async"
                      />
                    ) : (
                      <>
                        <div
                          class="absolute inset-0"
                          style="background-image: radial-gradient(rgba(0,229,255,0.05) 1px, transparent 1px); background-size: 20px 20px;"
                          aria-hidden="true"
                        ></div>
                        <span class="font-mono text-ncr-cyan/30 text-4xl font-bold select-none" aria-hidden="true">
                          NCR
                        </span>
                      </>
                    )}
                  </div>

                  <!-- Card body -->
                  <div class="flex flex-col flex-1 p-7">
                    <!-- Date + author -->
                    <div class="flex items-center gap-3 mb-4">
                      <time
                        datetime={post.data.pubDate.toISOString()}
                        class="font-mono text-xs text-ncr-muted tracking-wide"
                      >
                        {formatDate(post.data.pubDate)}
                      </time>
                      <span class="text-ncr-border" aria-hidden="true">·</span>
                      <span class="font-mono text-xs text-ncr-muted">{post.data.author}</span>
                    </div>

                    <!-- Title -->
                    <h3 class="text-ncr-text font-bold text-lg leading-snug mb-3 group-hover:text-ncr-cyan transition-colors duration-200">
                      {post.data.title}
                    </h3>

                    <!-- Description -->
                    <p class="text-ncr-muted text-sm leading-relaxed flex-1">
                      {post.data.description}
                    </p>

                    <!-- Read more -->
                    <div class="mt-6 flex items-center gap-1.5 font-mono text-xs text-ncr-cyan tracking-widest uppercase group-hover:gap-3 transition-all duration-200">
                      Read Article
                      <svg width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="square" aria-hidden="true">
                        <path d="M2 6h8M6 2l4 4-4 4"/>
                      </svg>
                    </div>
                  </div>
                </a>
              </li>
            ))}
          </ul>
        )}
      </div>
    </section>

  </main>

  <Footer />
</Layout>
