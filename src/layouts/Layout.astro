---
export interface Props {
  title?: string;
  description?: string;
  canonicalUrl?: string;
  ogImage?: string;
}

const {
  title = 'NCR Digital | Technical SEO for High-Growth Ventures',
  description = 'Boutique technical SEO agency delivering data-driven growth for startups and mid-market firms. Core Web Vitals, content strategy, and domain authority acceleration.',
  canonicalUrl = Astro.url.href,
  ogImage,
} = Astro.props;

const schema = {
  '@context': 'https://schema.org',
  '@type': 'ProfessionalService',
  name: 'NCR Digital',
  url: 'https://ncrdigi.com',
  description,
  email: 'niekos.c.robbins+ncr@gmail.com',
  founder: {
    '@type': 'Person',
    name: 'Niekos Robbins',
    alumniOf: {
      '@type': 'CollegeOrUniversity',
      name: 'Texas A&M University',
    },
  },
  knowsAbout: ['Technical SEO', 'Core Web Vitals', 'Content Strategy', 'Financial Modeling', 'Python'],
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'SEO Services',
    itemListElement: [
      {
        '@type': 'Offer',
        itemOffered: {
          '@type': 'Service',
          name: 'Technical SEO Audit',
          description: 'Comprehensive Core Web Vitals, crawl analysis, and structured data implementation',
        },
      },
      {
        '@type': 'Offer',
        itemOffered: {
          '@type': 'Service',
          name: 'Content Strategy',
          description: 'Topical authority building, content mapping, and semantic clustering',
        },
      },
      {
        '@type': 'Offer',
        itemOffered: {
          '@type': 'Service',
          name: 'Data-Backed Growth',
          description: 'Multi-channel SEO with GA4 analytics and conversion tracking',
        },
      },
    ],
  },
};
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="NCR Digital" />

    <!-- Open Graph image (set per-page via ogImage prop) -->
    {ogImage && <meta property="og:image" content={ogImage} />}
    {ogImage && <meta property="og:image:width" content="1200" />}
    {ogImage && <meta property="og:image:height" content="630" />}

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {ogImage && <meta name="twitter:image" content={ogImage} />}

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Fonts: preconnect first, then load only needed weights -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Roboto+Mono:wght@400;500;700&display=swap"
      rel="stylesheet"
    />

    <title>{title}</title>

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </head>

  <body class="bg-ncr-bg text-ncr-text antialiased font-sans">
    <slot />
  </body>
</html>

<style is:global>
  /* Custom scrollbar for dark theme */
  ::-webkit-scrollbar          { width: 5px; }
  ::-webkit-scrollbar-track    { background: #020509; }
  ::-webkit-scrollbar-thumb    { background: #0f2040; border-radius: 4px; }
  ::-webkit-scrollbar-thumb:hover { background: #00e5ff; }

  /* Smooth focus outlines */
  :focus-visible { outline: 2px solid #00e5ff; outline-offset: 2px; }

  /* Selection color */
  ::selection { background: rgba(0, 229, 255, 0.25); color: #e8f0fe; }
</style>
